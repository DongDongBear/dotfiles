# ============================================
# 动动的 Ghostty Config
# 纯终端开发环境，搭配 Claude Code 使用
# 重载：Cmd + Shift + ,
# ============================================

# === 字体 ===
font-family = "Maple Mono NF CN"
font-size = 14
font-thicken = true
adjust-cell-height = 2

# === 主题 ===
theme = Solarized Dark Higher Contrast

# === 窗口 ===
background-opacity = 0.88
background-blur-radius = 25
macos-titlebar-style = transparent
window-padding-x = 10
window-padding-y = 8
window-save-state = always
window-theme = auto
window-colorspace = display-p3

# === 终端 ===
term = xterm-256color
scrollback-limit = 10000000
shell-integration = zsh
confirm-close-surface = false

# === 光标 ===
cursor-style = bar
cursor-style-blink = true
cursor-opacity = 0.8

# === 鼠标 ===
mouse-hide-while-typing = true
copy-on-select = clipboard

# === 安全 ===
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true

# === Quick Terminal (从顶部下拉) ===
quick-terminal-position = top
quick-terminal-screen = mouse
quick-terminal-autohide = true
quick-terminal-animation-duration = 0.15

# === macOS 特有 ===
macos-option-as-alt = left

# === 启动行为 ===
initial-window = true
quit-after-last-window-closed = true

# === 快捷键 ===
# 分屏
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down
keybind = super+shift+enter=toggle_split_zoom
keybind = super+w=close_surface

# 分屏导航
keybind = super+alt+left=goto_split:left
keybind = super+alt+right=goto_split:right
keybind = super+alt+up=goto_split:top
keybind = super+alt+down=goto_split:bottom

# Tab
keybind = super+t=new_tab
keybind = super+shift+left=previous_tab
keybind = super+shift+right=next_tab

# 字体大小
keybind = super+equal=increase_font_size:1
keybind = super+minus=decrease_font_size:1
keybind = super+0=reset_font_size

# 全屏
keybind = super+f=toggle_fullscreen
